# Netlify Redirects
# Clean URLs (remove .html extension)
/index.html  /  301
/carta.html  /carta  301
/nosotros.html  /nosotros  301
/contacto.html  /contacto  301

# Pretty URLs for direct access
/carta  /carta.html  200
/nosotros  /nosotros.html  200
/contacto  /contacto.html  200

# Admin access via query param (already handled by JS)
/*?admin=1  /:splat  200

# Legacy / old URLs
/menu  /carta  301
/about  /nosotros  301
/contact  /contacto  301

# SPA fallback (not needed for static site, but safe)
/*  /404.html  404